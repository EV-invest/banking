# Copy to `.env` and adjust. Loaded by dotenvy in development.
# The signer is a SEPARATE process and a separate trust domain from the hub: it
# holds the chain private keys encrypted at rest and is the only process that ever
# sees the KEK.

# The signer's OWN database — separate from the hub's DATABASE_URL, so a hub-side
# compromise can't even read the (already-encrypted) wallet_secrets.
# `nix run .#db` boots a local Postgres and creates this database too.
SIGNER_DATABASE_URL=postgres://postgres@localhost:5432/ev_banking_signer

# Internal hub↔signer gRPC listener.
SIGNER_GRPC_ADDR=0.0.0.0:50053

# The 32-byte key-encrypting key as 64 hex chars. MUST be injected from a secrets
# store/KMS in production — NEVER commit a real KEK, and never store it next to the
# ciphertext. Fail-fast: the signer refuses to start without a valid 32-byte KEK.
# Generate a dev key:  openssl rand -hex 32
WALLET_KEK=

RUST_LOG=info,piggybank_signer=debug
