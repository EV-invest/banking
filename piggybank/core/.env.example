# Copy to `.env` and adjust. Loaded by dotenvy in development.
# `nix run .#db` boots a local Postgres matching this URL (trust auth, no password).
DATABASE_URL=postgres://postgres@localhost:5432/ev_fund
# Core gRPC services (data plane: health/users/balance/allocations).
GRPC_ADDR=0.0.0.0:50051
# Auth service gRPC (token issuance routes for clients), run as its own task.
AUTH_GRPC_ADDR=0.0.0.0:50052
RUST_LOG=info,piggybank_core=debug,evfund_auth=debug

# Central auth only: refresh-token rotation / revocation store. NOT per-service —
# services verify access tokens statelessly against cached JWKS. Leave unset to disable.
# `nix run .#redis` boots a local Redis matching this URL.
REDIS_URL=

# Sentry error tracking (optional — disabled when unset)
SENTRY_DSN=
APP_ENV=development

# TigerBeetle (financial ledger — authoritative money)
# `nix run .#tb` boots a local TigerBeetle matching this address.
TIGERBEETLE_ADDRESS=127.0.0.1:3033
TIGERBEETLE_CLUSTER_ID=0
