# Copy to `.env` and adjust. Loaded by dotenvy in development.
# `nix run .#db` boots a local Postgres matching this URL (trust auth, no password).
DATABASE_URL=postgres://postgres@localhost:5432/ev_banking
# Core gRPC services (data plane: health/users/balance/allocations). Loopback by
# default — widen only behind network segmentation (see docs/ARCHITECTURE.md).
GRPC_ADDR=127.0.0.1:50051
# Auth service gRPC (token issuance routes for clients), run as its own task.
AUTH_GRPC_ADDR=127.0.0.1:50052
RUST_LOG=info,piggybank_core=debug,evbanking_auth=debug

# Central auth only: refresh-token rotation / revocation store. NOT per-service —
# services verify access tokens statelessly against cached JWKS. `nix run .#redis` boots
# a local Redis matching this URL. Set it to back the refresh store with Redis (shared
# across replicas, durable across restarts); leave unset to keep the in-process store
# (single-instance/dev — no-op-until-configured, so local/CI is unaffected).
REDIS_URL=

# ── Cross-plane bridge consumer (identity → money) ────────────────────────────
# This hub PULLS concierge's user_outbox (UserEvents.PullUserLifecycle) to freeze /
# gate money ops on suspended/revoked users. Both must be set together (a half-config
# is an error, not a silent no-op); leave both unset to not consume (dev/CI default).
# CONCIERGE_BRIDGE_ADDR is the concierge runner's gRPC endpoint; BRIDGE_SERVICE_TOKEN
# is the shared bearer token and MUST match the value on the concierge side.
CONCIERGE_BRIDGE_ADDR=
BRIDGE_SERVICE_TOKEN=
# Seconds between bridge polls (default 5).
BRIDGE_POLL_SECS=5

# ── Auth service (token issuance) ─────────────────────────────────────────────
# All optional: with no signing key the auth service runs inert (mints/authorizes
# nothing), so the hub still boots locally. To enable, generate an Ed25519 keypair:
#   openssl genpkey -algorithm ed25519 -out auth_ed25519.pem
# then set the PEM, a kid, and the matching public JWKS (a {"keys":[{OKP…}]} JSON).
AUTH_SIGNING_KEY_PEM=
AUTH_SIGNING_KID=
AUTH_JWKS_JSON=
# Issuer + audiences (defaults shown). Client access tokens carry the client aud;
# service tokens the service aud — distinct, so the two JWT directions stay apart.
# (Refresh tokens are opaque rotated handles, not JWTs, so they have no audience.)
AUTH_ISSUER=https://auth.banking.ev
AUTH_CLIENT_AUDIENCE=banking-core
AUTH_SERVICE_AUDIENCE=banking-services
# Token TTLs in seconds (defaults: 15 min access, 30 d refresh, 5 min service).
AUTH_ACCESS_TTL_SECS=900
AUTH_REFRESH_TTL_SECS=2592000
AUTH_SERVICE_TTL_SECS=300

# Google OAuth2 confidential client (the BFF starts the redirect; the auth service
# does the code→token exchange). Empty ⇒ the Exchange route is disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin allowlist: comma-separated hub user ids (UUIDs) permitted to call the admin
# RPCs (RevokeTokens/DisableUser). Empty ⇒ no admins. A coarse stand-in for RBAC.
ADMIN_SUBJECTS=

# Sentry error tracking via ev::error_monitoring (optional — disabled when unset)
SENTRY_DSN=
APP_ENV=development

# PostHog product analytics via ev::analytics (optional — capture is a no-op when
# POSTHOG_KEY is unset). POSTHOG_HOST defaults to https://us.i.posthog.com.
POSTHOG_KEY=
POSTHOG_HOST=

# TigerBeetle (financial ledger — authoritative money)
# `nix run .#tb` boots a local TigerBeetle matching this address.
TIGERBEETLE_ADDRESS=127.0.0.1:3033
TIGERBEETLE_CLUSTER_ID=0

# Signer (the separate-process key vault) gRPC endpoint. The hub provisions
# key-backed deposit addresses through it. `nix run .#signer` boots it on :50053.
# Loopback `http://` is the single-host exception; an off-host `https://` target makes
# the hub require TLS on the seam (SIGNER_TLS_* below).
SIGNER_GRPC_ADDR=http://127.0.0.1:50053

# The signer authenticates callers — attach the hub's service token (typ=service,
# aud=banking-services) to onward calls. Out-of-band until the MintServiceToken RPC lands.
# SERVICE_TOKEN=

# Client TLS for an off-host (`https://`) signer. Pin the signer's CA (else public roots);
# add a client cert/key to present the hub's certificate for mTLS.
# SIGNER_TLS_CA_PEM_FILE=
# SIGNER_TLS_CLIENT_CERT_PEM_FILE=
# SIGNER_TLS_CLIENT_KEY_PEM_FILE=
