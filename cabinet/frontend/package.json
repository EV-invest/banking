{
  "name": "@evbanking/cabinet",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Host shell for the EV banking cabinet. Composes microfrontends (React and Rust/WASM) as custom elements; same-origin /api/* is proxied to the cabinet backend (the Rust BFF in cabinet/backend).",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "node --test --experimental-strip-types 'shared/**/*.test.ts'",
    "gen:api": "openapi-ts",
    "build:mfe": "node mfe/build.mjs && tailwindcss -i mfe/account-chip/mfe.css -o public/mfe/account-chip.css --minify",
    "predev": "npm run build:mfe",
    "prebuild": "npm run build:mfe"
  },
  "dependencies": {
    "@evinvest/analytics": "^0.1.2",
    "@evinvest/error-monitoring": "^0.1.0",
    "@evinvest/experiments": "^0.1.0",
    "@evinvest/uikit": "^0.6.0",
    "@sentry/nextjs": "^10.58.0",
    "@sentry/node": "^10.58.0",
    "@sentry/react": "^10.58.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.390.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-qr-code": "^2.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@hey-api/openapi-ts": "^0.98.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3"
  }
}
