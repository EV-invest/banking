# Copy to `.env` and adjust. The cabinet BFF orchestrates two gRPC planes and serves the
# browser's `/api/*` over HTTP (the Next.js frontend rewrites `/api/*` here).
# Topology (CABINET_BACKEND_BIND / PIGGYBANK_GRPC_ADDR / BANKING_AUTH_GRPC_ADDR /
# CONCIERGE_GRPC_ADDR) DEFAULTS from flake.nix; anything set here or in the
# environment wins. Normally this file holds secrets and per-machine overrides.

# Shared bearer the BFF presents on banking IssueUserToken (the concierge→banking seam). Must
# match BANKING_ISSUANCE_TOKEN on the banking side. Unset ⇒ no money pair is minted (money
# routes surface NotConfigured); the concierge identity login still works.
BANKING_ISSUANCE_TOKEN=

# ── Auth / OAuth (BFF token-handler) ──────────────────────────────────────────
# Google OAuth2 — only the PUBLIC client id lives here (the secret is in concierge's
# auth module). The redirect URI must match the one registered with Google and
# concierge's config; the flake defaults it to the frontend port. Empty client id
# ⇒ /api/auth/login returns 503.
GOOGLE_CLIENT_ID=
#AUTH_REDIRECT_URI=
# Cookie security: `__Host-`+Secure cookies need HTTPS, which http://localhost rejects —
# leave false in local dev, true in production (or unset to infer from APP_ENV).
AUTH_COOKIE_SECURE=false

# Microfrontend registry served at /api/mfe-registry (relative to the repo root cwd).
# The BFF validates it against a strict schema + this origin allow-list before serving,
# so a poisoned entry never reaches the browser that injects it as first-party <script>.
MFE_REGISTRY_PATH=cabinet/frontend/mfe-registry.json
# Cross-origin MFE bundle origins (scheme://host[:port], space/comma-separated). Mirrors
# the frontend CSP allow-list. Cross-origin entries also require an SRI integrity hash.
# Same-origin (relative) scriptUrls need no entry.
MFE_ALLOWED_ORIGINS=

# ── Session store ─────────────────────────────────────────────────────────────
# Server-side session store (the BFF holds the concierge token pair; the browser gets
# only an opaque session cookie). Set to back sessions with Redis (shared across replicas,
# durable across restarts); leave unset to keep the in-process map (single-instance/dev —
# no-op-until-configured, so local/CI is unaffected). `nix run .#redis` boots a local Redis.
SESSION_REDIS_URL=

# ── Observability (all optional; each integration no-ops when unset) ──────────
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=
APP_ENV=development
