# Copy to `.env` and adjust. The cabinet BFF orchestrates two gRPC planes and serves the
# browser's `/api/*` over HTTP (the Next.js frontend rewrites `/api/*` here).

# HTTP listener — the frontend's CABINET_BACKEND_URL points at this.
CABINET_BACKEND_BIND=0.0.0.0:4000

# ── Upstream planes ───────────────────────────────────────────────────────────
# Money plane (wallet/funds/health) — the piggybank hub core.
PIGGYBANK_GRPC_ADDR=http://127.0.0.1:50051
# Identity plane (OAuth/sessions/profile) — the concierge runner. Run it from the
# sibling `concierge` repo (its `nix run` app) for the auth/profile/session flows.
CONCIERGE_GRPC_ADDR=http://127.0.0.1:50061

# ── Auth / OAuth (BFF token-handler) ──────────────────────────────────────────
# Google OAuth2 — only the PUBLIC client id lives here (the secret is in concierge's
# auth module). The redirect URI must match the one registered with Google and
# concierge's config. Empty ⇒ /api/auth/login returns 503.
GOOGLE_CLIENT_ID=
AUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Cookie security: `__Host-`+Secure cookies need HTTPS, which http://localhost rejects —
# leave false in local dev, true in production (or unset to infer from APP_ENV).
AUTH_COOKIE_SECURE=false

# Microfrontend registry served at /api/mfe-registry (relative to the repo root cwd).
MFE_REGISTRY_PATH=clients/cabinet/frontend/mfe-registry.json

# ── Observability (all optional; each integration no-ops when unset) ──────────
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=
APP_ENV=development
