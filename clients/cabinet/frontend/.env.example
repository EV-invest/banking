# Copy to `.env.local` and adjust. The cabinet BFF talks to the hub's gRPC backend.

# Hub gRPC address (the backend's GRPC_ADDR). The BFF dials this server-side.
GRPC_ADDR=127.0.0.1:50051

# Where the BFF reads the proto for the runtime gRPC client (proto-loader).
# Defaults to the in-repo contracts/proto.
# GRPC_PROTO_DIR=../../contracts/proto

# ── Auth / OAuth (BFF token-handler) ──────────────────────────────────────────
# The hub auth service (token issuance) the BFF dials server-side. Empty/default
# is fine locally; the login flow no-ops until GOOGLE_CLIENT_ID is set.
AUTH_GRPC_ADDR=127.0.0.1:50052
# Google OAuth2 — only the PUBLIC client id lives here (the secret is in the hub
# auth task). The redirect URI must match the one registered with Google and the
# hub's AUTH_REDIRECT_URI. Empty ⇒ the cabinet's /api/auth/login returns 503.
GOOGLE_CLIENT_ID=
AUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Cookie security: `__Host-`+Secure cookies need HTTPS, which http://localhost
# rejects — leave false in local dev, true in production (or unset to infer from
# NODE_ENV).
AUTH_COOKIE_SECURE=false
# Server-side session store. This slice keeps sessions in-process (single-instance
# /dev). PRODUCTION: back them with this Redis (a store DISTINCT from the auth
# service's refresh-rotation Redis). Unused while unset.
SESSION_REDIS_URL=

# Content-Security-Policy MFE allow-list. The host derives script-src/connect-src
# origins from mfe-registry.json; add any production CDN origins for remotes not in
# that file here (space/comma-separated). Same-origin remotes need no entry.
MFE_ALLOWED_ORIGINS=

# ── Observability (all optional; each integration no-ops when unset) ──────────

# Product analytics (PostHog) — browser. Empty key → capture is a silent no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error monitoring (Sentry) — browser provider + ErrorBoundary.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development

# Error monitoring (Sentry) — server/runtime (instrumentation.ts → register).
SENTRY_DSN=
APP_ENV=development

# Build-time Sentry source-map upload (optional; upload skipped when unset).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
