# Copy to `.env.local` and adjust. The cabinet BFF talks to the hub's gRPC backend.

# Hub gRPC address (the backend's GRPC_ADDR). The BFF dials this server-side.
GRPC_ADDR=127.0.0.1:50051

# Where the BFF reads the proto for the runtime gRPC client (proto-loader).
# Defaults to the in-repo contracts/proto.
# GRPC_PROTO_DIR=../../contracts/proto

# ── Observability (all optional; each integration no-ops when unset) ──────────

# Product analytics (PostHog) — browser. Empty key → capture is a silent no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error monitoring (Sentry) — browser provider + ErrorBoundary.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development

# Error monitoring (Sentry) — server/runtime (instrumentation.ts → register).
SENTRY_DSN=
APP_ENV=development

# Build-time Sentry source-map upload (optional; upload skipped when unset).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
